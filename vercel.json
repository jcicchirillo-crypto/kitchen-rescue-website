{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/send-quote-email", "destination": "/api/server.js" },
    { "source": "/api/(.*)", "destination": "/api/server.js" }
  ],
  "functions": {
    "api/server.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
